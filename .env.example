# VoiceGov Scanner — Environment Variables
# Copy to .env and fill in your values

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Deepgram
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server
PORT=3500
LEADERBOARD_PORT=3501
HOST=voicegov.thebhtlabs.com

# Scanning
MAX_CONCURRENT_CALLS=6
CALLS_PER_DAY=50
CALL_TIMEOUT_SEC=120
SCAN_START_HOUR=9
SCAN_END_HOUR=17

# Timezone
TZ=America/New_York
